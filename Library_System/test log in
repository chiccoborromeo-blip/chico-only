<?php
ini_set('session.save_path', '/Applications/XAMPP/xamppfiles/temp/');
session_start();
require 'includes/db_connect.php';

if (isset($_SESSION['user_id'])) {
    if ($_SESSION['role'] === 'admin') {
        header("Location: dashboard.php");
    } else {
        header("Location: user_dashboard.php");
    }
    exit();
}

$error = "";

// Catch the error message if security.php kicked them out
if (isset($_SESSION['status'])) {
    $error = $_SESSION['status'];
    unset($_SESSION['status']); // Clear it so it doesn't show forever
}

if (isset($_POST['login'])) {
    $email    = trim($_POST['email']);
    $password = trim($_POST['password']);

    $sql  = "SELECT * FROM users WHERE email = ?";
    $stmt = mysqli_prepare($conn, $sql);
    mysqli_stmt_bind_param($stmt, "s", $email);
    mysqli_stmt_execute($stmt);
    $result = mysqli_stmt_get_result($stmt);
    $user   = mysqli_fetch_assoc($result);

    if ($user && password_verify($password, $user['password'])) {
        $_SESSION['user_id']   = $user['id'];
        $_SESSION['user_name'] = $user['name'];
        $_SESSION['role']      = $user['role'];
        
        // SECURITY ADDITION: Save their IP address to prevent Session Hijacking
        $_SESSION['user_ip']   = $_SERVER['REMOTE_ADDR'];

        if ($user['role'] === 'admin') {
            $_SESSION['toast'] = [
                'type'    => 'success',
                'message' => 'Welcome back, ' . $user['name'] . '! You are logged in as Admin.'
            ];
            header("Location: dashboard.php");
        } else {
            $_SESSION['toast'] = [
                'type'    => 'success',
                'message' => 'Welcome back, ' . $user['name'] . '! Enjoy your reading. 📚'
            ];
            header("Location: user_dashboard.php");
        }
        exit();
    } else {
        $error = "Invalid email or password.";
    }
}
